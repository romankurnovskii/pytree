{
  "name": "pytree",
  "version": "1.3.0",
  "description": "Print python project tree structure with classes and methods",
  "license": "MIT",
  "homepage": "https://github.com/romankurnovskii/pytree#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/romankurnovskii/pytree.git"
  },
  "bugs": {
    "url": "https://github.com/romankurnovskii/pytree/issues"
  },
  "keywords": [
    "pytree",
    "tree",
    "npm-module",
    "print-python-methods"
  ],
  "author": {
    "name": "Roman Kurnovskii",
    "email": "r.kurnovskii@gmail.com",
    "url": "https://romankurnovskii.com"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": "dist/bin.js",
  "scripts": {
    "start": "ts-node-esm src/bin.ts",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "lint": "eslint \"{**/*,*}.{ts,tsx}\"",
    "lint:fix": "eslint --fix",
    "format": "prettier --write \"{src,tests,example/src}/**/*.{js,ts,jsx,tsx}\"",
    "prettier": "prettier --write \"{src,tests,example/src}/**/*.{js,ts,jsx,tsx}\"",
    "test": "jest --config jestconfig.json",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build && npm test && npm run prettier && npm run lint"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.0.2",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.11.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^30.0.0",
    "prettier": "^3.0.3",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.3",
    "@types/jest": "^30.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "tsx": "^4.21.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
